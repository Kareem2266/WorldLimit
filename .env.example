# WorldLimit — Environment Variable Template
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.
# This file (.env.example) is safe to commit — it has no real secrets.

# ── PostgreSQL ───────────────────────────────────────────────────
# These are the credentials for your local development database.
# The DATABASE_URL combines them into one connection string that
# SQLAlchemy (our Python database library) uses to connect.
# Format: postgresql+asyncpg://user:password@host:port/database_name
POSTGRES_USER=worldlimit
POSTGRES_PASSWORD=worldlimit_dev
POSTGRES_DB=worldlimit
DATABASE_URL=postgresql+asyncpg://worldlimit:worldlimit_dev@postgres:5432/worldlimit

# ── Redis ────────────────────────────────────────────────────────
# Redis is our message broker — it sits between the API and the
# background worker. "redis" here is the container name (not localhost)
# because both services are on the same Docker network.
REDIS_URL=redis://redis:6379/0

# ── Anthropic ────────────────────────────────────────────────────
# We'll use this later for prompt enhancement. Leave blank for now.
ANTHROPIC_API_KEY=

# ── App ──────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change_this_to_a_long_random_string_in_production
